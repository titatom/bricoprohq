# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-random-secret

# Admin login credentials
ADMIN_EMAIL=admin@bricopro.local
ADMIN_PASSWORD=change-me-secure-password

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=bricopro

# ── Ports (change if something else is already on these) ──────────────────────
WEB_PORT=3000
API_PORT=8000

# ── OAuth (Jobber + Google Calendar) ─────────────────────────────────────────
# Public base URL of this app — used to build OAuth callback URLs.
# Must match the Redirect URIs registered in each provider's developer console.
# Example: https://hq.yourdomain.com
APP_BASE_URL=http://localhost:3000

# Optional: set explicit callback URLs per provider instead of using APP_BASE_URL:
# JOBBER_REDIRECT_URI=https://hq.yourdomain.com/api/integrations/jobber/oauth/callback
# GOOGLE_CALENDAR_REDIRECT_URI=https://hq.yourdomain.com/api/integrations/google_calendar/oauth/callback
# GOOGLE_BUSINESS_REDIRECT_URI=https://hq.yourdomain.com/api/integrations/google_business/oauth/callback
# META_REDIRECT_URI=https://hq.yourdomain.com/api/integrations/meta/oauth/callback
