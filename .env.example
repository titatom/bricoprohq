# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# In production (APP_ENV=production) the app refuses to start when this is
# missing or left at the default placeholder.
SECRET_KEY=change-me-generate-a-random-secret

# Admin login credentials
ADMIN_EMAIL=admin@bricopro.local
ADMIN_PASSWORD=change-me-secure-password

# ── Hardening ─────────────────────────────────────────────────────────────────
# APP_ENV=production enables strict checks (refuse default SECRET_KEY, log
# critical warnings if ADMIN_PASSWORD is left at the default).
APP_ENV=production

# CORS: by default the API only accepts the APP_BASE_URL origin (and
# localhost:3000 when APP_BASE_URL is unset). Add a comma-separated list of
# extra origins here, or "*" to allow any origin (sets allow_credentials=false
# automatically because browsers reject credentialed wildcard CORS).
# CORS_ALLOWED_ORIGINS=https://staff.example.com,https://other.example.com

# Login rate limit: per (client IP, email) pair. Defaults shown.
# LOGIN_RATE_LIMIT=10
# LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# ── Persistence ───────────────────────────────────────────────────────────────
# SQLite is used by default and stored at /data/bricoprohq.db in the container.
# docker-compose.yml maps that to the app_data volume. Override only if needed.
# DATABASE_URL=sqlite+pysqlite:////data/bricoprohq.db
# DATA_DIR=/data
# Host path mounted to /data by docker-compose.yml.
APPDATA_PATH=./data

# ── Ports (change if something else is already on these) ──────────────────────
WEB_PORT=3000

# ── OAuth (Jobber + Google Calendar) ─────────────────────────────────────────
# Public base URL of this app — used to build OAuth callback URLs.
# Must match the Redirect URIs registered in each provider's developer console.
# Example: https://hq.yourdomain.com
APP_BASE_URL=http://localhost:3000

# Optional: set explicit callback URLs per provider instead of using APP_BASE_URL:
# JOBBER_REDIRECT_URI=https://hq.yourdomain.com/api/integrations/jobber/oauth/callback
# GOOGLE_CALENDAR_REDIRECT_URI=https://hq.yourdomain.com/api/integrations/google_calendar/oauth/callback
# GOOGLE_BUSINESS_REDIRECT_URI=https://hq.yourdomain.com/api/integrations/google_business/oauth/callback
# META_REDIRECT_URI=https://hq.yourdomain.com/api/integrations/meta/oauth/callback
# INSTAGRAM_REDIRECT_URI=https://hq.yourdomain.com/api/integrations/instagram/oauth/callback

# ── Instagram Webhooks ────────────────────────────────────────────────────────
# Set this to any secret string you choose, then enter the same value in the
# Meta developer portal: Instagram product → Webhooks → Verify Token.
# Webhook Callback URL: https://hq.yourdomain.com/api/integrations/instagram/webhook
# (This is separate from the OAuth redirect URI above.)
# INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your-secret-verify-token-here
