# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-random-secret

# Admin login credentials
ADMIN_EMAIL=admin@bricopro.local
ADMIN_PASSWORD=change-me-secure-password

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=bricopro

# ── Ports (change if something else is already on these) ──────────────────────
WEB_PORT=3000
API_PORT=8000

# ── Jobber OAuth ───────────────────────────────────────────────────────────────
# Public base URL of this app (used to build the Jobber OAuth callback URL).
# Must match the Redirect URI registered in developer.getjobber.com.
# Example: https://hq.yourdomain.com
APP_BASE_URL=http://localhost:3000
# Or set the full callback URL explicitly:
# JOBBER_REDIRECT_URI=https://hq.yourdomain.com/api/integrations/jobber/oauth/callback
