# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-random-secret

# Admin login
ADMIN_EMAIL=admin@bricopro.local
ADMIN_PASSWORD=change-me-secure-password

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=bricopro

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production

# URL the frontend uses to reach the API
# For Unraid: use your server's LAN IP, e.g. http://192.168.1.100:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
