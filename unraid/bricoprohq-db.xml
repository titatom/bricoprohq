<?xml version="1.0"?>
<Container version="2">
  <Name>bricoprohq-db</Name>
  <Repository>postgres:16-alpine</Repository>
  <Registry>https://hub.docker.com</Registry>
  <Network>bricoprohq</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project>https://github.com/titatom/bricoprohq</Project>
  <Overview>PostgreSQL database for Bricopro HQ. Start this before bricoprohq-api.</Overview>
  <Category>Tools:</Category>
  <WebUI/>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/titatom/bricoprohq/main/docs/icon.png</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>

  <Config Name="Data Volume" Target="/var/lib/postgresql/data" Default="/mnt/user/appdata/bricoprohq/db" Description="Persistent storage for the database. Must survive container restarts." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/bricoprohq/db</Config>

  <Config Name="Database Name" Target="POSTGRES_DB" Default="bricoprohq" Description="Database name." Type="Variable" Display="advanced" Required="true" Mask="false">bricoprohq</Config>

  <Config Name="Database User" Target="POSTGRES_USER" Default="bricopro" Description="Database username." Type="Variable" Display="advanced" Required="true" Mask="false">bricopro</Config>

  <Config Name="Database Password" Target="POSTGRES_PASSWORD" Default="bricopro" Description="Database password. Must match the DATABASE_URL in bricoprohq-api." Type="Variable" Display="always" Required="true" Mask="true">bricopro</Config>
</Container>
