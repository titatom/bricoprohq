<?xml version="1.0"?>
<Container version="2">
  <Name>bricoprohq-redis</Name>
  <Repository>redis:7-alpine</Repository>
  <Registry>https://hub.docker.com</Registry>
  <Network>bricoprohq</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project>https://github.com/titatom/bricoprohq</Project>
  <Overview>Redis cache for Bricopro HQ. Start this before bricoprohq-api.</Overview>
  <Category>Tools:</Category>
  <WebUI/>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/titatom/bricoprohq/main/docs/icon.png</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>

  <Config Name="Data Volume" Target="/data" Default="/mnt/user/appdata/bricoprohq/redis" Description="Persistent storage for Redis. Optional but recommended." Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/bricoprohq/redis</Config>
</Container>
